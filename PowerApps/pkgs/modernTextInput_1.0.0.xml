<widget xmlns="http://openajax.org/metadata" xmlns:appMagic="http://schemas.microsoft.com/appMagic" spec="1.0" id="http://microsoft.com/appmagic/modernTextInput" name="modernTextInput" jsClass="AppMagic.Controls.ModernTextInputControl" enabledForFeatureGate="Controls.ModernTextInputControl" version="1.0.0" styleable="true" runtimeCost="1">
